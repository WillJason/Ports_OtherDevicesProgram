  16          /*********************************************************************************************
  17                  功能描述： 定时器0初始化函数
  18                  入口参数： 无
  19                  返回参数： 无
  20                  函数说明： 5ms的定时        
  21          **********************************************************************************************/
  22          void timer0_init(void)   
  23          {                                       
  24   1          AUXR |= 0x80;                                                 //定时器时钟1T模式
  25   1              TMOD &= 0xF0;                                             //设置定时器模式
  26   1              TMOD |= 0x01;                                             //设置定时器模式
  27   1          TL0 = 0x18;                                               //设置定时初值
  28   1              TH0 = 0x23;                                                   //设置定时初值
  29   1              TF0 = 0;                                                      //清除TF0标志
  30   1              TR0 = 0;                                                      //定时器0初始不允许计时   
  31   1              ET0 = 1;                                                          //定时器0中断允许使能
  32   1              EA = 1;                                                           //中断总允许使能
  33   1              timer0_10s_counter = 0;                                                           //定时器0用于10s的计数值
  34   1              timer0_10s_counter2= 0;
  35   1          timer0_30s_counter = 0;                               //定时器0用于30s的计数值
  36   1          timer0_30s_counter2= 0;
  37   1      }
  38          /*********************************************************************************************
  39                  功能描述： 定时器0中断服务函数
  40                  入口参数： 无
  41                  返回参数： 无
  42                  函数说明： 每5ms完成一次中断，执行一次中断服务程序
  43                                     为了防止程序中30s的计时数据和连续10s内输入的计时数据发生混乱，采用两种独立的计数
  44                                     变量，这样对其中一个进行重新计时操作，不会影响到另一个计时操作。
  45                                              
  46          *********************************************************************************************/
  47          void tm0_isr() interrupt 1 using 1       
  48          {
  49   1              TL0 = 0x18;     
  50   1              TH0 = 0x23;
  51   1              /*****************10s计时用代码***********************/
  52   1              timer0_10s_counter++;                                                             //记录5ms的次数
  53   1              if(timer0_10s_counter >= 100)                                                     //达到500ms
  54   1              {
C51 COMPILER V9.00   TIMER                                                                 05/22/2018 18:34:07 PAGE 2   

  55   2                      timer0_10s_counter=0;
  56   2                      timer0_10s_counter2++;                                                    //记录500ms的次数
  57   2                      if(timer0_10s_counter2 >= 10)                                             //10个500ms达到5s
  58   2                      {
  59   3                              timer0_10s_counter2=0;
  60   3                              //5秒计时完成
  61   3                              Arrival_5s_10Part++;                                              //记录5s的次数
  62   3                      }
  63   2              }
  64   1              if(Arrival_5s_10Part >= 2)                                                        //达到10s
  65   1              {
  66   2                      //relay_port=~relay_port;                                                 //调试用
  67   2                      Arrival_5s_10Part=0;
  68   2                      Arrival_10s_10Part=1;                                                     //达到10s的标志位
  69   2              }
  70   1              /*****************30s计时用代码***********************/
  71   1              if(allow_30s)
  72   1              {
  73   2                      timer0_30s_counter++;                                                             //记录5ms的次数
