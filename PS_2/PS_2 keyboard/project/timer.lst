  88   5                                              {
  89   6                                                      Arrival_10s_30Part=0;
  90   6                                                      Part_30s_State=1;                                                                         //返回1表示计时到达30s
  91   6                                              }
  92   5                                      }
  93   4                              }
  94   3                      }       
  95   2              }       
  96   1       } 
